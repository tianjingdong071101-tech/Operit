+    private fun extractAiTools() {
+        val aiToolsDir = File(filesDir, "ai-tools")
+        if (aiToolsDir.exists()) {
+            Log.d(TAG, "AI tools directory already exists, skipping extraction.")
+            return
+        }
+        val archiveFile = File(filesDir, AI_TOOLS_FILENAME)
+        if (!archiveFile.exists()) {
+            Log.w(TAG, "AI tools archive not found: $AI_TOOLS_FILENAME")
+            return
+        }
+        try {
+            aiToolsDir.mkdirs()
+            val process = ProcessBuilder(
+                File(binDir, "busybox").absolutePath,
+                "tar", "-xJf", archiveFile.absolutePath,
+                "-C", aiToolsDir.absolutePath
+            ).apply {
+                environment()["LD_LIBRARY_PATH"] = nativeLibDir
+            }.start()
+            val exitCode = process.waitFor()
+            if (exitCode != 0) {
+                Log.e(TAG, "Failed to extract AI tools archive, exit code: $exitCode")
+                return
+            }
+            Log.d(TAG, "AI tools archive extracted successfully")
+
+            writeClaudeLauncher()
+            writeOpenCodeLauncher()
+            setupNodeSymlink()
+
+            archiveFile.delete()
+            Log.d(TAG, "AI tools setup completed")
+        } catch (e: Exception) {
+            Log.e(TAG, "Failed to extract AI tools", e)
+        }
+    }
+
+    private fun writeClaudeLauncher() {
+        val launcher = File(binDir, "claude")
+        val glibLib = File(filesDir, "ai-tools/glibc/lib").absolutePath
+        val linker = File(filesDir, "ai-tools/glibc/lib/ld-linux-aarch64.so.1").absolutePath
+        val claudeBin = File(filesDir, "ai-tools/claude/bin/claude-code-linux-arm64/claude").absolutePath
+        val bashPath = File(binDir, "bash").absolutePath
+
+        val script = """#$bashPath
+GLIB_LIB=$glibLib
+unset LD_PRELOAD
+export LD_LIBRARY_PATH=${'$'}GLIB_LIB${'$'}{LD_LIBRARY_PATH:+:${'$'}LD_LIBRARY_PATH}
+exec $linker --library-path ${'$'}GLIB_LIB $claudeBin "${'$'}@"
+"""
+        launcher.writeText(script.trimIndent())
+        launcher.setExecutable(true, false)
+        Log.d(TAG, "Created claude launcher at ${launcher.absolutePath}")
+    }
+
+    private fun writeOpenCodeLauncher() {
+        val launcher = File(binDir, "opencode")
+        val glibLib = File(filesDir, "ai-tools/glibc/lib").absolutePath
+        val linker = File(filesDir, "ai-tools/glibc/lib/ld-linux-aarch64.so.1").absolutePath
+        val opencodeBin = File(filesDir, "ai-tools/opencode/opencode").absolutePath
+        val bashPath = File(binDir, "bash").absolutePath
+
+        val script = """#$bashPath
+GLIB_LIB=$glibLib
+unset LD_PRELOAD
+export LD_LIBRARY_PATH=${'$'}GLIB_LIB${'$'}{LD_LIBRARY_PATH:+:${'$'}LD_LIBRARY_PATH}
+exec $linker --library-path ${'$'}GLIB_LIB $opencodeBin "${'$'}@"
+"""
+        launcher.writeText(script.trimIndent())
+        launcher.setExecutable(true, false)
+        Log.d(TAG, "Created opencode launcher at ${launcher.absolutePath}")
+    }
+
+    private fun setupNodeSymlink() {
+        val nodeBin = File(filesDir, "ai-tools/node/bin/node")
+        val nodeLink = File(binDir, "node")
+        if (nodeBin.exists() && !nodeLink.exists()) {
+            try {
+                Files.createSymbolicLink(nodeLink.toPath(), nodeBin.toPath())
+                Log.d(TAG, "Created node symlink at ${nodeLink.absolutePath}")
+            } catch (e: Exception) {
+                Log.e(TAG, "Failed to create node symlink", e)
+            }
+        }
+    }
